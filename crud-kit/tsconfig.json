{
  "compilerOptions": {

    "target": "ES2017",

    "module": "ESNext",

    "moduleResolution": "bundler",

    "jsx": "react-jsx",

    "declaration": true,

    "outDir": "dist",

    "strict": true,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "ignoreDeprecations": "6.0"
  },

  "include": ["src"]
}